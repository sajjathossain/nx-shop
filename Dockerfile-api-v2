FROM node:20-alpine AS builder
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

RUN pnpm nx build @org/api-v2 --configuration=production

FROM node:20-alpine AS runner
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

# Only copy what's needed for production
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
# Copy all workspace package.jsons to maintain monorepo structure
COPY apps/api-v2/package.json ./apps/api-v2/
COPY libs/api/products/package.json ./libs/api/products/
COPY libs/shared/models/package.json ./libs/shared/models/

# Install only production dependencies
RUN pnpm install --prod --frozen-lockfile

# Copy the built application and necessary config files for migrations
# Maintain structure so relative tsconfig paths work
COPY --from=builder /app/apps/api-v2/dist ./apps/api-v2/dist
COPY --from=builder /app/apps/api-v2/typeorm.config.ts ./apps/api-v2/
COPY --from=builder /app/apps/api-v2/tsconfig.app.json ./apps/api-v2/
COPY --from=builder /app/apps/api-v2/src/app/migrations ./apps/api-v2/src/app/migrations
COPY --from=builder /app/apps/api-v2/scripts ./apps/api-v2/scripts

# Expose port 4000
EXPOSE 4000

# Run migrations and then start the server from the app directory
CMD ["sh", "-c", "cd apps/api-v2 && node ./scripts/migration-run.js && node dist/main.js"]
